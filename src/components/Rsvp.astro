---
import type { Translation } from '@/i18n/en';

interface Props {
  t: Translation;
}
const { t } = Astro.props;

// TODO: replace with your real Google Form embed URL
const googleFormUrl = 'https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform?embedded=true';
const googleFormDirectUrl = 'https://forms.gle/hJH4iYuGwA9f1RGK8';
const useEmbed = false; // set to true to embed form inline instead of link
---

<section id="rsvp" class="py-20 px-4 bg-sage/10">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="section-title">{t.rsvp.title}</h2>
    <p class="mt-4 text-charcoal/60 text-sm">{t.rsvp.description}</p>

    {useEmbed ? (
      <div class="mt-10 rounded-2xl overflow-hidden shadow-md border border-sage/30">
        <iframe
          src={googleFormUrl}
          width="100%"
          height="900"
          title="RSVP Form"
          style="border: 0; margin: 0;"
        >
          Loading…
        </iframe>
      </div>
    ) : (
      <a
        href={googleFormDirectUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block mt-10 bg-gold text-white font-sans text-sm tracking-widest uppercase px-10 py-4 rounded-full shadow-md hover:bg-gold/80 transition"
      >
        {t.rsvp.buttonLabel}
      </a>
    )}
  </div>
</section>
