---
import type { Translation } from '@/i18n/en';

interface Props {
  t: Translation;
}
const { t } = Astro.props;
---

<section id="faq" class="py-20 px-4 max-w-3xl mx-auto">
  <h2 class="section-title">{t.faq.title}</h2>

  <dl class="mt-10 space-y-6">
    {t.faq.items.map((item) => (
      <div class="border-b border-blush/30 pb-6">
        <dt class="font-serif text-xl text-charcoal mb-2">{item.q}</dt>
        <dd class="text-charcoal/65 text-sm leading-relaxed">{item.a}</dd>
      </div>
    ))}
  </dl>
</section>
