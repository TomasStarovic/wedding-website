---
import type { Translation } from '@/i18n/en';

interface Props {
  t: Translation;
}
const { t } = Astro.props;

---

<section
  id="home"
  class="relative min-h-[90vh] flex flex-col items-center justify-center text-center px-4 py-20 overflow-hidden"
>
  <!-- Soft background decoration -->
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-blush/20 via-ivory to-ivory" />
  <div
    class="absolute -top-32 -left-32 w-96 h-96 rounded-full bg-blush/20 blur-3xl -z-10"
  />
  <div
    class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full bg-sage/20 blur-3xl -z-10"
  />

  <!-- Cartoonish couple placeholder -->
  <div class="mb-6 w-40 h-40 mx-auto rounded-full bg-blush/30 border-4 border-gold/40 flex items-center justify-center text-5xl select-none">
    💍
  </div>

  <p class="font-sans text-sm tracking-[0.3em] uppercase text-gold mb-2">
    {t.hero.subtitle}
  </p>

  <h1 class="font-serif text-5xl md:text-7xl text-charcoal leading-tight mb-4">
    Tomáš <span class="text-gold">&amp;</span> Emma
  </h1>

  <p class="font-serif italic text-2xl text-charcoal/60 mb-8">
    {t.hero.date} &nbsp;·&nbsp; {t.hero.timeAndPlace} &nbsp;·&nbsp; {t.hero.location}
  </p>

  <div class="mt-2">
    <a
      href="#rsvp"
      class="inline-block bg-gold text-white font-sans text-sm tracking-widest uppercase px-8 py-3 rounded-full shadow hover:bg-gold/80 transition"
    >
      {t.rsvp.buttonLabel}
    </a>
  </div>
</section>
