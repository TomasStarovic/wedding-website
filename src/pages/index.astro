---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import Venue from '@/components/Venue.astro';
import Schedule from '@/components/Schedule.astro';
import Seating from '@/components/Seating.astro';
import Gift from '@/components/Gift.astro';
import Rsvp from '@/components/Rsvp.astro';
import { t, type Locale } from '@/i18n/index';
import '@/styles/global.css';

const locale: Locale = 'sk';
const translations = t(locale);
const previewMode = Astro.url.searchParams.get('preview') === '1';
const showSchedule = previewMode;
const showSeating = previewMode;
---

<Layout title="Emma & Tomáš – Svadba 2026" locale={locale}>
  <!-- Nav links slot -->
  <Fragment slot="nav-links">
    <li><a href="#venue"    class="hover:text-gold transition">{translations.nav.venue}</a></li>
    {showSchedule && <li><a href="#schedule" class="hover:text-gold transition">{translations.nav.schedule}</a></li>}
    {showSeating && <li><a href="#seating"  class="hover:text-gold transition">{translations.nav.seating}</a></li>}
    <li><a href="#rsvp"     class="hover:text-gold transition">{translations.nav.rsvp}</a></li>
  </Fragment>

  <Hero t={translations} />
  <Venue t={translations} />
  {showSchedule && <Schedule t={translations} />}
  {showSeating && <Seating t={translations} />}
  <Gift t={translations} />
  <Rsvp t={translations} />

  <!-- Footer slot -->
  <Fragment slot="footer">
    {translations.contact.footer}
  </Fragment>
</Layout>
